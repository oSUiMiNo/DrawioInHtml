{
  "name": "drawio-in-html",
  "displayName": "Drawio in HTML",
  "description": "Preview HTML files inline in VSCode with embedded Drawio diagrams rendered as live SVG, then edit each diagram in a side tab and auto-save back to the same HTML file.",
  "version": "0.5.0",
  "publisher": "Maku",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/oSUiMiNo/DrawioInHtml.git"
  },
  "bugs": {
    "url": "https://github.com/oSUiMiNo/DrawioInHtml/issues"
  },
  "homepage": "https://github.com/oSUiMiNo/DrawioInHtml#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "drawio",
    "diagrams.net",
    "diagram",
    "html",
    "embed",
    "viewer",
    "mxgraph"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "drawioInHtml.editor",
        "displayName": "Drawio HTML Editor",
        "selector": [
          {
            "filenamePattern": "*.html"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "drawioInHtml.openPreview",
        "title": "Open Preview",
        "category": "Drawio in HTML"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "drawioInHtml.openPreview",
          "when": "resourceExtname == .html",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "command": "drawioInHtml.openPreview",
          "when": "resourceExtname == .html"
        }
      ],
      "commandPalette": [
        {
          "command": "drawioInHtml.openPreview",
          "when": "resourceExtname == .html"
        }
      ]
    },
    "keybindings": [
      {
        "command": "drawioInHtml.openPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname == .html && !inDiffEditor"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "fetch-viewer": "node scripts/fetch-viewer.js",
    "postinstall": "node scripts/fetch-viewer.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "node-html-parser": "^6.1.13"
  }
}
